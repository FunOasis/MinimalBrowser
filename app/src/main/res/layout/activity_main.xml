<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:elevation="0dp">

        <!-- Toolbar only for menu/title — hidden visually -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#000000" />

        <!-- Navigation row — outside Toolbar to avoid touch interception -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#000000"
            android:paddingHorizontal="4dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:enabled="false"
                android:tint="#FFFFFF" />

            <!-- Forward -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                android:enabled="false"
                android:layout_marginStart="2dp"
                android:tint="#FFFFFF" />

            <!-- Address bar — tappable, shows search dialog -->
            <TextView
                android:id="@+id/addressBar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/address_bar_bg"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:hint="Search or enter URL"
                android:singleLine="true"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true" />

            <!-- Blocked badge -->
            <TextView
                android:id="@+id/blockedBadge"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:background="@drawable/badge_bg"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:paddingHorizontal="6dp"
                android:visibility="gone"
                android:fontFamily="monospace"
                android:gravity="center_vertical" />

            <!-- Reload -->
            <ImageButton
                android:id="@+id/btnReload"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_reload"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reload"
                android:tint="#FFFFFF" />

        </LinearLayout>

        <!-- Page title -->
        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:paddingHorizontal="16dp"
            android:textSize="11sp"
            android:textColor="#888888"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:visibility="gone"
            android:progressTint="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Home page -->
    <FrameLayout
        android:id="@+id/homePage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:paddingHorizontal="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P R S"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:letterSpacing="0.3"
                android:layout_marginBottom="48dp"
                android:fontFamily="serif" />

            <!-- Dummy search bar — tap opens dialog -->
            <TextView
                android:id="@+id/homeSearchBar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/home_search_bg"
                android:paddingHorizontal="20dp"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:hint="Search the web"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

    </FrameLayout>

    <!-- WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
